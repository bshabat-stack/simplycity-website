{
  "cleanUrls": false,
  "trailingSlash": false,
  "functions": {
    "api/blog-posts.js": { "includeFiles": "content/blog/**" },
    "api/sitemap.js": { "includeFiles": "content/blog/**" },
    "api/blog-post.js": { "includeFiles": "{BlogPost.dc.html,404.html,es/BlogPost.dc.html,es/404.html,he/BlogPost.dc.html,he/404.html,content/blog/**}" }
  },
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/local-seo-agency", "destination": "/LocalSEOAgency.dc.html" },
    { "source": "/local-seo-for-small-business", "destination": "/LocalSEOForSmallBusiness.dc.html" },
    { "source": "/google-business-profile-optimization", "destination": "/GoogleBusinessProfileOptimization.dc.html" },
    { "source": "/local-seo-for-restaurants", "destination": "/LocalSEOForRestaurants.dc.html" },
    { "source": "/local-seo-for-beauty-wellness", "destination": "/LocalSEOForBeautyWellness.dc.html" },
    { "source": "/local-seo-for-retail", "destination": "/LocalSEOForRetail.dc.html" },
    { "source": "/local-seo-pricing", "destination": "/Pricing.dc.html" },
    { "source": "/results", "destination": "/Results.dc.html" },
    { "source": "/audit", "destination": "/Audit.dc.html" },
    { "source": "/about", "destination": "/About.dc.html" },
    { "source": "/contact", "destination": "/Contact.dc.html" },
    { "source": "/blog", "destination": "/Blog.dc.html" },
    { "source": "/blog/:slug", "destination": "/api/blog-post?locale=en&slug=:slug" },
    { "source": "/:locale(es|he)/local-seo-agency", "destination": "/:locale/LocalSEOAgency.dc.html" },
    { "source": "/:locale(es|he)/local-seo-for-small-business", "destination": "/:locale/LocalSEOForSmallBusiness.dc.html" },
    { "source": "/:locale(es|he)/google-business-profile-optimization", "destination": "/:locale/GoogleBusinessProfileOptimization.dc.html" },
    { "source": "/:locale(es|he)/local-seo-pricing", "destination": "/:locale/Pricing.dc.html" },
    { "source": "/:locale(es|he)/results", "destination": "/:locale/Results.dc.html" },
    { "source": "/:locale(es|he)/audit", "destination": "/:locale/Audit.dc.html" },
    { "source": "/:locale(es|he)/about", "destination": "/:locale/About.dc.html" },
    { "source": "/:locale(es|he)/contact", "destination": "/:locale/Contact.dc.html" },
    { "source": "/:locale(es|he)/blog", "destination": "/:locale/Blog.dc.html" },
    { "source": "/:locale(es|he)/blog/:slug", "destination": "/api/blog-post?locale=:locale&slug=:slug" }
  ],
  "redirects": [
    { "source": "/LocalSEOAgency.dc.html", "destination": "/local-seo-agency", "permanent": true },
    { "source": "/LocalSEOForSmallBusiness.dc.html", "destination": "/local-seo-for-small-business", "permanent": true },
    { "source": "/GoogleBusinessProfileOptimization.dc.html", "destination": "/google-business-profile-optimization", "permanent": true },
    { "source": "/LocalSEOForRestaurants.dc.html", "destination": "/local-seo-for-restaurants", "permanent": true },
    { "source": "/LocalSEOForBeautyWellness.dc.html", "destination": "/local-seo-for-beauty-wellness", "permanent": true },
    { "source": "/LocalSEOForRetail.dc.html", "destination": "/local-seo-for-retail", "permanent": true },
    { "source": "/Pricing.dc.html", "destination": "/local-seo-pricing", "permanent": true },
    { "source": "/Results.dc.html", "destination": "/results", "permanent": true },
    { "source": "/Audit.dc.html", "destination": "/audit", "permanent": true },
    { "source": "/About.dc.html", "destination": "/about", "permanent": true },
    { "source": "/Contact.dc.html", "destination": "/contact", "permanent": true },
    { "source": "/Blog.dc.html", "destination": "/blog", "permanent": true },
    { "source": "/BlogPost.dc.html", "destination": "/blog", "permanent": true },
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/:locale(es|he)/LocalSEOAgency.dc.html", "destination": "/:locale/local-seo-agency", "permanent": true },
    { "source": "/:locale(es|he)/LocalSEOForSmallBusiness.dc.html", "destination": "/:locale/local-seo-for-small-business", "permanent": true },
    { "source": "/:locale(es|he)/GoogleBusinessProfileOptimization.dc.html", "destination": "/:locale/google-business-profile-optimization", "permanent": true },
    { "source": "/:locale(es|he)/Pricing.dc.html", "destination": "/:locale/local-seo-pricing", "permanent": true },
    { "source": "/:locale(es|he)/Results.dc.html", "destination": "/:locale/results", "permanent": true },
    { "source": "/:locale(es|he)/Audit.dc.html", "destination": "/:locale/audit", "permanent": true },
    { "source": "/:locale(es|he)/About.dc.html", "destination": "/:locale/about", "permanent": true },
    { "source": "/:locale(es|he)/Contact.dc.html", "destination": "/:locale/contact", "permanent": true },
    { "source": "/:locale(es|he)/Blog.dc.html", "destination": "/:locale/blog", "permanent": true },
    { "source": "/:locale(es|he)/BlogPost.dc.html", "destination": "/:locale/blog", "permanent": true },
    { "source": "/:locale(es|he)/index.html", "destination": "/:locale", "permanent": true }
  ]
}
